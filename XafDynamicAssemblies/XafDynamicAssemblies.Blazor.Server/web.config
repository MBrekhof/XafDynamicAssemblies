<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!--
        Out-of-process hosting: ANCM runs Kestrel as a separate process.
        When the app exits (e.g. Environment.Exit(42) for Deploy restart),
        ANCM automatically restarts it — no wrapper script needed.

        startupTimeLimit: 120s to allow for Roslyn compilation on cold start.
      -->
      <aspNetCore processPath="dotnet"
                  arguments=".\XafDynamicAssemblies.Blazor.Server.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="OutOfProcess"
                  startupTimeLimit="120" />
    </system.webServer>
  </location>
</configuration>
